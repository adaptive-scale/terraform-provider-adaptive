```

### SSH Server

```terraform
resource "adaptive_resource" "ssh" {
  name     = "bastion-host"
  type     = "ssh"
  host     = "bastion.example.com"
  port     = "22"
  username = "admin"
  key      = file("~/.ssh/id_rsa")
  tags     = ["infrastructure"]
